{
  "name": "aria-assistant",
  "version": "1.0.0",
  "description": "ARIA - AI Desktop Assistant powered by Claude",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.aria.assistant",
    "productName": "ARIA Assistant",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "ARIA-Assistant-Setup.exe"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!*.md"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
