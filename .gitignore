# Dependencies — run "npm install" to recreate this
node_modules/

# Vite / React build output — run "npm run build" to recreate
dist/

# Electron build output
out/
build/

# Whisper binaries and models (user downloads these locally on first run)
whisper/
*.bin
*.dll

# User data — contains API keys, never commit these
config.json
memory.json

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo
